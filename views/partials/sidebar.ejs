<div class="sidebar">
  <div class="brand">
    <h2><i class="fas fa-graduation-cap"></i> ExamHub</h2>
    <small>Online Examination System</small>
  </div>
  <nav>
    <% if (user && user.role === 'admin') { %>
      <a href="/admin" class="nav-link"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/students" class="nav-link"><i class="fas fa-user-graduate"></i> Students</a>
      <a href="/admin/faculty" class="nav-link"><i class="fas fa-chalkboard-teacher"></i> Faculty</a>
      <a href="/admin/subjects" class="nav-link"><i class="fas fa-book"></i> Subjects</a>
      <a href="/admin/exams" class="nav-link"><i class="fas fa-calendar-alt"></i> Exams</a>
      <a href="/admin/questions" class="nav-link"><i class="fas fa-question-circle"></i> Question Bank</a>
      <a href="/admin/hall-tickets" class="nav-link"><i class="fas fa-id-card"></i> Hall Tickets</a>
      <a href="/admin/results" class="nav-link"><i class="fas fa-poll"></i> Results</a>
      <a href="/admin/analytics" class="nav-link"><i class="fas fa-chart-bar"></i> Analytics</a>
    <% } else if (user && user.role === 'faculty') { %>
      <a href="/faculty" class="nav-link"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/faculty/questions" class="nav-link"><i class="fas fa-question-circle"></i> Question Bank</a>
      <a href="/faculty/marks" class="nav-link"><i class="fas fa-pen-alt"></i> Mark Entry</a>
      <a href="/faculty/results" class="nav-link"><i class="fas fa-poll"></i> Results</a>
    <% } else if (user && user.role === 'student') { %>
      <a href="/student" class="nav-link"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/student/exams" class="nav-link"><i class="fas fa-laptop"></i> Take Exam</a>
      <a href="/student/hall-tickets" class="nav-link"><i class="fas fa-id-card"></i> Hall Tickets</a>
      <a href="/student/results" class="nav-link"><i class="fas fa-poll"></i> Results</a>
    <% } %>
    <a href="/logout" class="nav-link" style="margin-top:30px; border-top:1px solid rgba(255,255,255,0.1); padding-top:20px;">
      <i class="fas fa-sign-out-alt"></i> Logout
    </a>
  </nav>
</div>

<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="topbar">
    <h1>My Results</h1>
  </div>

  <% if (student) { %>
  <div class="card">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>#</th><th>Exam</th><th>Subject</th><th>Marks</th><th>Percentage</th><th>Grade</th><th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% results.forEach((r, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= r.exam_name %></td>
            <td><%= r.subject_name %> (<%= r.subject_code %>)</td>
            <td><%= r.marks_obtained !== null ? r.marks_obtained : '-' %> / <%= r.total_marks %></td>
            <td><%= r.percentage %>%</td>
            <td><strong><%= r.grade %></strong></td>
            <td>
              <span class="badge badge-<%= r.result_status === 'pass' ? 'success' : r.result_status === 'fail' ? 'danger' : 'secondary' %>">
                <%= r.result_status.toUpperCase() %>
              </span>
            </td>
          </tr>
          <% }) %>
          <% if (results.length === 0) { %>
          <tr><td colspan="7" style="text-align:center; color:#999;">No results published yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (results.length > 0) { %>
  <div class="card">
    <h2>Summary</h2>
    <div class="stats-grid">
      <div class="stat-card">
        <h3><%= results.length %></h3>
        <p>Total Exams</p>
      </div>
      <div class="stat-card">
        <h3><%= results.filter(r => r.result_status === 'pass').length %></h3>
        <p>Passed</p>
      </div>
      <div class="stat-card">
        <h3><%= results.length > 0 ? (results.reduce((sum, r) => sum + parseFloat(r.percentage), 0) / results.length).toFixed(1) : 0 %>%</h3>
        <p>Average Percentage</p>
      </div>
    </div>
  </div>
  <% } %>
  <% } else { %>
  <div class="card">
    <p style="text-align:center; color:#999;">Student profile not found. Contact administrator.</p>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>

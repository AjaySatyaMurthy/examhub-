<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="topbar">
    <h1>Faculty Management</h1>
    <button class="btn btn-primary" onclick="toggleModal('addFacultyModal')">+ Add Faculty</button>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% faculty.forEach((f, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= f.name %></td>
            <td><%= f.email %></td>
            <td><%= f.phone || '-' %></td>
            <td>
              <button class="btn btn-warning btn-sm" onclick='editFaculty(<%= JSON.stringify({id: f.id, name: f.name, email: f.email, phone: f.phone || ""}) %>)'>Edit</button>
              <form method="POST" action="/admin/faculty/delete/<%= f.id %>" style="display:inline;" onsubmit="return confirm('Delete this faculty?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (faculty.length === 0) { %>
          <tr><td colspan="5" style="text-align:center; color:#999;">No faculty added yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Faculty Modal -->
<div class="modal-overlay" id="addFacultyModal">
  <div class="modal">
    <h2>Add Faculty</h2>
    <form method="POST" action="/admin/faculty/add">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" class="form-control" required minlength="6">
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" class="form-control">
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="toggleModal('addFacultyModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Add Faculty</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Faculty Modal -->
<div class="modal-overlay" id="editFacultyModal">
  <div class="modal">
    <h2>Edit Faculty</h2>
    <form method="POST" id="editFacultyForm">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" id="editFacultyName" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" id="editFacultyEmail" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" id="editFacultyPhone" class="form-control">
      </div>
      <div class="form-group">
        <label>New Password (leave blank to keep current)</label>
        <input type="password" name="password" class="form-control" minlength="6">
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="toggleModal('editFacultyModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
function editFaculty(f) {
  document.getElementById('editFacultyForm').action = '/admin/faculty/edit/' + f.id;
  document.getElementById('editFacultyName').value = f.name;
  document.getElementById('editFacultyEmail').value = f.email;
  document.getElementById('editFacultyPhone').value = f.phone;
  toggleModal('editFacultyModal');
}
</script>
<%- include('../partials/footer') %>

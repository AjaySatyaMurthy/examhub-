<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="topbar">
    <h1>Exam Scheduling</h1>
    <button class="btn btn-primary" onclick="toggleModal('addExamModal')">+ Schedule Exam</button>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>#</th><th>Exam Name</th><th>Subject</th><th>Date</th><th>Time</th><th>Room</th><th>Total Marks</th><th>Status</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% exams.forEach((e, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= e.name %></td>
            <td><%= e.subject_name %> (<%= e.subject_code %>)</td>
            <td><%= new Date(e.exam_date).toLocaleDateString() %></td>
            <td><%= e.start_time %> - <%= e.end_time %></td>
            <td><%= e.room || '-' %></td>
            <td><%= e.total_marks %></td>
            <td>
              <span class="badge badge-<%= e.status === 'completed' ? 'success' : e.status === 'cancelled' ? 'danger' : 'warning' %>">
                <%= e.status %>
              </span>
            </td>
            <td>
              <button class="btn btn-warning btn-sm" onclick='editExam(<%= JSON.stringify({id: e.id, name: e.name, subject_id: e.subject_id, exam_date: new Date(e.exam_date).toISOString().split("T")[0], start_time: e.start_time, end_time: e.end_time, total_marks: e.total_marks, passing_marks: e.passing_marks, room: e.room || "", status: e.status}) %>)'>Edit</button>
              <form method="POST" action="/admin/exams/delete/<%= e.id %>" style="display:inline;" onsubmit="return confirm('Delete this exam?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (exams.length === 0) { %>
          <tr><td colspan="9" style="text-align:center; color:#999;">No exams scheduled yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Exam Modal -->
<div class="modal-overlay" id="addExamModal">
  <div class="modal">
    <h2>Schedule New Exam</h2>
    <form method="POST" action="/admin/exams/add">
      <div class="form-group">
        <label>Exam Name</label>
        <input type="text" name="name" class="form-control" required placeholder="e.g., Mid Semester Exam - DBMS">
      </div>
      <div class="form-group">
        <label>Subject</label>
        <select name="subject_id" class="form-control" required>
          <option value="">Select Subject</option>
          <% subjects.forEach(s => { %>
          <option value="<%= s.id %>"><%= s.name %> (<%= s.code %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Date</label>
          <input type="date" name="exam_date" class="form-control" required>
        </div>
        <div class="form-group">
          <label>Room</label>
          <input type="text" name="room" class="form-control" placeholder="e.g., Hall-A">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Start Time</label>
          <input type="time" name="start_time" class="form-control" required>
        </div>
        <div class="form-group">
          <label>End Time</label>
          <input type="time" name="end_time" class="form-control" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Total Marks</label>
          <input type="number" name="total_marks" class="form-control" value="100" required>
        </div>
        <div class="form-group">
          <label>Passing Marks</label>
          <input type="number" name="passing_marks" class="form-control" value="40" required>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="toggleModal('addExamModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Schedule Exam</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Exam Modal -->
<div class="modal-overlay" id="editExamModal">
  <div class="modal">
    <h2>Edit Exam</h2>
    <form method="POST" id="editExamForm">
      <div class="form-group">
        <label>Exam Name</label>
        <input type="text" name="name" id="editExamName" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Subject</label>
        <select name="subject_id" id="editExamSubject" class="form-control" required>
          <% subjects.forEach(s => { %>
          <option value="<%= s.id %>"><%= s.name %> (<%= s.code %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Date</label>
          <input type="date" name="exam_date" id="editExamDate" class="form-control" required>
        </div>
        <div class="form-group">
          <label>Room</label>
          <input type="text" name="room" id="editExamRoom" class="form-control">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Start Time</label>
          <input type="time" name="start_time" id="editExamStart" class="form-control" required>
        </div>
        <div class="form-group">
          <label>End Time</label>
          <input type="time" name="end_time" id="editExamEnd" class="form-control" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Total Marks</label>
          <input type="number" name="total_marks" id="editExamTotal" class="form-control" required>
        </div>
        <div class="form-group">
          <label>Passing Marks</label>
          <input type="number" name="passing_marks" id="editExamPassing" class="form-control" required>
        </div>
      </div>
      <div class="form-group">
        <label>Status</label>
        <select name="status" id="editExamStatus" class="form-control" required>
          <option value="scheduled">Scheduled</option>
          <option value="ongoing">Ongoing</option>
          <option value="completed">Completed</option>
          <option value="cancelled">Cancelled</option>
        </select>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="toggleModal('editExamModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
function editExam(e) {
  document.getElementById('editExamForm').action = '/admin/exams/edit/' + e.id;
  document.getElementById('editExamName').value = e.name;
  document.getElementById('editExamSubject').value = e.subject_id;
  document.getElementById('editExamDate').value = e.exam_date;
  document.getElementById('editExamStart').value = e.start_time;
  document.getElementById('editExamEnd').value = e.end_time;
  document.getElementById('editExamTotal').value = e.total_marks;
  document.getElementById('editExamPassing').value = e.passing_marks;
  document.getElementById('editExamRoom').value = e.room;
  document.getElementById('editExamStatus').value = e.status;
  toggleModal('editExamModal');
}
</script>
<%- include('../partials/footer') %>
